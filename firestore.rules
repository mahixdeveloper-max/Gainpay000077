rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - phone: string (required)
    //   - walletAddress: string (required)
    //   - encryptedPrivateKey: string (required)
    //   - balance: number (required)
    //   - isBlocked: boolean (required)
    //   - role: string (required, enum: ["admin", "user"])
    //   - createdAt: number (required)
    //   - referralCode: string (required)
    //   - referredBy: string (optional)
    //   - upiId: string (optional)
    //
    // Collection: transactions
    // Document ID: {txId}
    // Fields:
    //   - userId: string (required)
    //   - type: string (required, enum: ["deposit", "buy", "sell", "transfer"])
    //   - amount: number (required)
    //   - status: string (required, enum: ["pending", "approved", "rejected", "completed"])
    //   - txHash: string (optional)
    //   - createdAt: number (required)
    //   - utr: string (optional)
    //   - method: string (optional, enum: ["UPI", "USDT"])
    //
    // Collection: buyRequests
    // Document ID: {requestId}
    // Fields:
    //   - userId: string (required)
    //   - amount: number (required)
    //   - status: string (required, enum: ["pending", "approved", "rejected"])
    //   - utr: string (optional)
    //   - screenshot: string (optional, URL or Base64)
    //   - userUpiId: string (optional)
    //   - createdAt: number (required)
    //
    // Collection: sellRequests
    // Document ID: {requestId}
    // Fields:
    //   - userId: string (required)
    //   - amount: number (required)
    //   - status: string (required, enum: ["pending", "approved", "rejected"])
    //   - upiId: string (required)
    //   - createdAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (
          (request.auth.token.email == "moddagudurapukara@gmail.com" && request.auth.token.email_verified == true) ||
          (request.auth.token.email == "6491643491@gainpay.com") ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasRequiredFields(['uid', 'phone', 'walletAddress', 'encryptedPrivateKey', 'balance', 'isBlocked', 'role', 'createdAt', 'referralCode']) &&
             data.uid is string &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.walletAddress is string &&
             data.encryptedPrivateKey is string &&
             data.balance is number && data.balance >= 0 &&
             data.isBlocked is bool &&
             data.role in ['admin', 'user'] &&
             data.createdAt is number &&
             data.referralCode is string &&
             (!('lastProfitDate' in data) || data.lastProfitDate is string) &&
             (!('bonusClaimed' in data) || data.bonusClaimed is bool) &&
             (!('completedTasks' in data) || data.completedTasks is list) &&
             (!('sellRestrictedUntil' in data) || data.sellRestrictedUntil is number) &&
             (!('upiIds' in data) || data.upiIds is list);
    }

    function isValidTransaction(data) {
      return hasRequiredFields(['userId', 'type', 'amount', 'status', 'createdAt']) &&
             data.userId is string &&
             data.type in ['deposit', 'buy', 'sell', 'transfer', 'commission', 'reward'] &&
             data.amount is number && data.amount >= 0 &&
             data.status in ['pending', 'approved', 'rejected', 'completed'] &&
             data.createdAt is number;
    }

    function isValidBuyRequest(data) {
      return hasRequiredFields(['userId', 'amount', 'status', 'createdAt']) &&
             data.userId is string &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!('utr' in data) || (data.utr is string && data.utr.size() <= 100)) &&
             (!('screenshot' in data) || (data.screenshot is string && data.screenshot.size() <= 2000000)) &&
             (!('userUpiId' in data) || (data.userUpiId is string && data.userUpiId.size() <= 100)) &&
             (!('adminUpiId' in data) || (data.adminUpiId is string && data.adminUpiId.size() <= 100)) &&
             (!('optionId' in data) || (data.optionId is string)) &&
             (!('rewardPercent' in data) || (data.rewardPercent is number)) &&
             data.createdAt is number;
    }

    function isValidSellRequest(data) {
      return hasRequiredFields(['userId', 'amount', 'status', 'upiId', 'createdAt']) &&
             data.userId is string &&
             data.amount is number && data.amount > 0 &&
             data.status in ['pending', 'approved', 'rejected'] &&
             data.upiId is string && data.upiId.size() <= 100 &&
             data.createdAt is number;
    }

    function isValidBuyOption(data) {
      return hasRequiredFields(['amount', 'status', 'createdAt', 'orderNo']) &&
             data.amount is number && data.amount > 0 &&
             data.status in ['available', 'pending', 'sold'] &&
             data.createdAt is number &&
             data.orderNo is string &&
             (!('upiId' in data) || (data.upiId is string && data.upiId.size() <= 100)) &&
             (!('rewardPercent' in data) || (data.rewardPercent is number));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin() || (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role);
    }

    // Transactions
    match /transactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && (isAdmin() || (isOwner(request.resource.data.userId) && request.resource.data.type in ['reward', 'commission'])) && isValidTransaction(request.resource.data);
      allow update: if isAdmin() && isValidTransaction(request.resource.data);
    }

    // Buy Requests
    match /buyRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId) && isValidBuyRequest(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidBuyRequest(request.resource.data);
    }

    // Sell Requests
    match /sellRequests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId) && isValidSellRequest(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if isAdmin() && isValidSellRequest(request.resource.data);
    }

    // Config
    match /config/{document} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Buy Options
    match /buyOptions/{optionId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && 
        ((isAdmin() && isValidBuyOption(request.resource.data)) || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) && request.resource.data.status == 'pending' && resource.data.status == 'available'));
      allow create: if isAdmin() && isValidBuyOption(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
